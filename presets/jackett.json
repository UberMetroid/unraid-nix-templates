{
  "name": "jackett",
  "display_name": "Jackett",
  "description": "Jackett API Proxy",
  "url": "https://github.com/Jackett/Jackett",
  "command": "exec nix run nixpkgs#jackett -- --DataFolder /config",
  "default_ports": [
    {
      "host": 9117,
      "container": 9117,
      "label": "HTTP"
    }
  ],
  "icon": "fa-search",
  "meta": {
    "version": "0.24.2021",
    "license": "GPL-2.0-only",
    "platforms": [
      "x86_64-linux",
      "aarch64-linux"
    ],
    "maintainers": [
      "nyanloutre",
      "purcell"
    ],
    "programs": [
      "Jackett",
      "jackett",
      "libMono.Unix.so"
    ]
  }
}

{
  "name": "prometheus",
  "display_name": "Prometheus",
  "description": "Prometheus Monitoring DB",
  "url": "https://prometheus.io/",
  "command": "exec nix run nixpkgs#prometheus -- --config.file=/config/prometheus.yml --storage.tsdb.path=/config/data",
  "default_ports": [
    {
      "host": 9090,
      "container": 9090,
      "label": "Web GUI"
    }
  ],
  "icon": "fa-bar-chart",
  "meta": {
    "version": "3.11.3",
    "license": "Apache-2.0",
    "platforms": [
      "aarch64-linux",
      "x86_64-linux"
    ],
    "maintainers": [
      "fpletz",
      "Frostman",
      "jpds"
    ],
    "programs": [
      "migrate",
      "prometheus"
    ]
  }
}

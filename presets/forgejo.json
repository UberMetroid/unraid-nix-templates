{
  "name": "forgejo",
  "display_name": "Forgejo",
  "description": "Forgejo Git Hosting Platform",
  "url": "https://forgejo.org/",
  "command": "exec nix run nixpkgs#forgejo -- web",
  "default_ports": [
    {
      "host": 3000,
      "container": 3000,
      "label": "HTTP"
    },
    {
      "host": 22,
      "container": 22,
      "label": "SSH"
    }
  ],
  "icon": "fa-server",
  "meta": {
    "version": "15.0.2",
    "license": "GPL-3.0-or-later",
    "platforms": [
      "aarch64-linux",
      "x86_64-linux"
    ],
    "maintainers": [
      "adamcstephens",
      "bendlas",
      "christoph-heiss"
    ],
    "programs": [
      "environment-to-ini",
      "forgejo"
    ]
  }
}

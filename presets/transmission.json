      "label": "Peer Port"
    }
  ],
  "icon": "fa-download",
  "meta": {
    "version": "4.1.1",
    "license": "",
    "platforms": [
      "aarch64-linux",
      "x86_64-linux"
    ],
    "maintainers": [
      "nyanloutre"
    ],
    "programs": [
      "transmission-cli",
      "transmission-create",
      "transmission-daemon",
      "transmission-edit",
      "transmission-remote",
      "transmission-show"
    ]
  }

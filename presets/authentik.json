{
  "name": "authentik",
  "display_name": "Authentik",
  "description": "Authentik Identity Portal",
  "url": "https://goauthentik.io/",
  "command": "exec nix run nixpkgs#authentik",
  "default_ports": [
    {
      "host": 9000,
      "container": 9000,
      "label": "HTTP"
    },
    {
      "host": 9443,
      "container": 9443,
      "label": "HTTPS"
    }
  ],
  "icon": "fa-lock",
  "meta": {
    "version": "2025.12.5",
    "license": "MIT",
    "platforms": [
      "aarch64-linux",
      "x86_64-linux"
    ],
    "maintainers": [
      "jvanbruegge",
      "rissson"
    ],
    "programs": [
      "ak"
    ]
  }
}

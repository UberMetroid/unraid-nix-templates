{
  "name": "audiobookshelf",
  "display_name": "Audiobookshelf",
  "description": "Audiobookshelf Book/Podcast Server",
  "url": "https://www.audiobookshelf.org/",
  "command": "exec nix run nixpkgs#audiobookshelf -- --config /config --metadata /config/metadata",
  "default_ports": [
    {
      "host": 8000,
      "container": 8000,
      "label": "HTTP"
    }
  ],
  "icon": "fa-book",
  "meta": {
    "version": "2.35.1",
    "license": "GPL-3.0",
    "platforms": [
      "aarch64-linux",
      "x86_64-linux"
    ],
    "maintainers": [
      "jvanbruegge",
      "adamcstephens",
      "tebriel"
    ],
    "programs": [
      "audiobookshelf"
    ]
  }
}

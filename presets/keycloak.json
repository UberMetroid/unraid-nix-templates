      "aarch64-linux"
    ],
    "maintainers": [
      "ngerstle",
      "talyz",
      "NickCao"
    ],
    "programs": [
      "client",
      "federation-sssd-setup.sh",
      "kc.sh",
      "kcadm.sh",
      "kcreg.sh"
    ]
  }

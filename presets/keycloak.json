  "url": "https://www.keycloak.org/",
  "command": "exec nix run nixpkgs#keycloak -- start-dev",
  "default_ports": [
    {
      "host": 8080,
      "container": 8080,
      "label": "Web GUI"
    }
  ],
  "icon": "fa-lock",
  "meta": {
    "version": "26.6.3",
    "license": "Apache-2.0",
    "platforms": [

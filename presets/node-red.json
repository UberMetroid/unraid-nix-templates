{
  "name": "node-red",
  "display_name": "Node-RED",
  "description": "Node-RED Logic Editor",
  "url": "https://nodered.org/",
  "command": "exec nix run nixpkgs#node-red -- --userDir /config",
  "default_ports": [
    {
      "host": 1880,
      "container": 1880,
      "label": "HTTP"
    }
  ],
  "icon": "fa-code-fork",
  "meta": {
    "version": "4.1.8",
    "license": "Apache-2.0",
    "platforms": [
      "aarch64-linux",
      "x86_64-linux"
    ],
    "maintainers": [
      "MatthewCroughan"
    ],
    "programs": [
      "node-red",
      "node-red-pi"
    ]
  }
}

{
  "name": "mosquitto",
  "display_name": "Mosquitto",
  "description": "Mosquitto MQTT Message Broker",
  "url": "https://mosquitto.org/",
  "command": "exec nix run nixpkgs#mosquitto -- -c /config/mosquitto.conf",
  "default_ports": [
    {
      "host": 1883,
      "container": 1883,
      "label": "MQTT"
    },
    {
      "host": 9001,
      "container": 9001,
      "label": "WebSockets"
    }
  ],
  "icon": "fa-server",
  "meta": {
    "version": "2.1.2",
    "license": "EPL-1.0",
    "platforms": [
      "aarch64-linux",
      "x86_64-linux"
    ],
    "maintainers": [
      "peterhoeg",
      "sikmir"
    ],
    "programs": [
      "mosquitto",
      "mosquitto_ctrl",
      "mosquitto_db_dump",
      "mosquitto_passwd",
      "mosquitto_pub",
      "mosquitto_rr",
      "mosquitto_signal",
      "mosquitto_sub"
    ]
  }
}

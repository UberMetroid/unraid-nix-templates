{
  "name": "jellyfin",
  "display_name": "Jellyfin",
  "description": "Jellyfin Media Server",
  "url": "https://jellyfin.org/",
  "command": "exec nix run nixpkgs#jellyfin -- --datadir /config/data --cachedir /config/cache --configdir /config/config",
  "default_ports": [
    {
      "host": 8096,
      "container": 8096,
      "label": "HTTP"
    },
    {
      "host": 8920,
      "container": 8920,
      "label": "HTTPS"
    },
    {
      "host": 1900,
      "container": 1900,
      "label": "DLNA (UDP)"
    },
    {
      "host": 7359,
      "container": 7359,
      "label": "Discovery (UDP)"
    }
  ],
  "icon": "fa-play-circle",
  "meta": {
    "version": "10.11.11",
    "license": "GPL-2.0-or-later",
    "platforms": [
      "x86_64-linux",
      "aarch64-linux"
    ],
    "maintainers": [
      "nyanloutre",
      "minijackson",
      "purcell"
    ],
    "programs": [
      "jellyfin"
    ]
  }
}

{
  "name": "clickhouse",
  "display_name": "ClickHouse",
  "description": "ClickHouse Analytical DB",
  "url": "https://clickhouse.com/",
  "command": "exec nix run nixpkgs#clickhouse",
  "default_ports": [
    {
      "host": 8123,
      "container": 8123,
      "label": "HTTP"
    },
    {
      "host": 9000,
      "container": 9000,
      "label": "Native"
    }
  ],
  "icon": "fa-database",
  "meta": {
    "version": "26.5.2.39-stable",
    "license": "Apache-2.0",
    "platforms": [
      "aarch64-linux",
      "x86_64-linux"
    ],
    "maintainers": [
      "thevar1able"
    ],
    "programs": [
      "ch",
      "chc",
      "chdig",
      "chl",
      "clickhouse",
      "clickhouse-benchmark",
      "clickhouse-chdig",
      "clickhouse-check-marks",
      "clickhouse-checksum-for-compressed-block",
      "clickhouse-client",
      "clickhouse-compressor",
      "clickhouse-disks",
      "clickhouse-docker-init",
      "clickhouse-extract-from-config",
      "clickhouse-format",
      "clickhouse-git-import",
      "clickhouse-keeper",
      "clickhouse-keeper-bench",
      "clickhouse-keeper-client",
      "clickhouse-keeper-converter",
      "clickhouse-keeper-data-dumper",
      "clickhouse-keeper-utils",
      "clickhouse-local",
      "clickhouse-obfuscator",
      "clickhouse-server",
      "clickhouse-static-files-disk-uploader",
      "clickhouse-su",
      "clickhouse-zookeeper-dump-tree",
      "clickhouse-zookeeper-remove-by-list"
    ]
  }
}

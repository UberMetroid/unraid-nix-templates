{
  "name": "filebrowser",
  "display_name": "Filebrowser",
  "description": "Lightweight web-based file manager and browser",
  "url": "https://filebrowser.org/",
  "command": "exec nix run nixpkgs#filebrowser -- --address 0.0.0.0 --port 8080 --database /config/filebrowser.db --root /config",
  "default_ports": [
    {
      "host": 8080,
      "container": 8080,
      "label": "Web GUI"
    }
  ],
  "icon": "fa-folder-open-o",
  "meta": {
    "version": "2.63.5",
    "license": "Apache-2.0",
    "platforms": [
      "aarch64-linux",
      "x86_64-linux"
    ],
    "maintainers": [
      "HritwikSinghal"
    ],
    "programs": [
      "filebrowser"
    ]
  }
}
